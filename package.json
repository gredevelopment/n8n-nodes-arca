{
	"name": "n8n-nodes-arca",
	"version": "1.0.2",
	"description": "N8N nodes for the Arca API, providing workspace, folder, list, task, status, label, and comment management.",
	"keywords": [
		"n8n-community-node-package",
		"arca",
		"workspace",
		"tasks",
		"api"
	],
	"license": "MIT",
	"homepage": "https://getarca.app/",
	"author": {
		"name": "GRE Development Ltd",
		"email": "info@getarca.app"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/gredevelopment/n8n-nodes-arca.git"
	},
	"main": "index.js",
	"scripts": {
		"build": "tsc && gulp build:icons",
		"dev": "tsc --watch",
		"format": "prettier nodes credentials --write",
		"lint": "eslint nodes credentials package.json",
		"lintfix": "eslint nodes credentials package.json --fix",
		"prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.js nodes credentials package.json",
		"release": "npm version patch && git push --follow-tags",
		"release:minor": "npm version minor && git push --follow-tags",
		"release:major": "npm version major && git push --follow-tags"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/ArcaApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Arca/Arca.node.js",
			"dist/nodes/ArcaTrigger/ArcaTrigger.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.23.0",
		"@typescript-eslint/parser": "~5.45",
		"eslint-plugin-n8n-nodes-base": "^1.11.0",
		"gulp": "^4.0.2",
		"n8n-workflow": "^2.13.1",
		"prettier": "^2.7.1",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
